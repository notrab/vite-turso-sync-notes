# Turso Database Configuration
# Copy this file to .env.local and fill in your actual values

# Your Turso database URL (get this from your Turso dashboard)
VITE_TURSO_URL=https://your-database-name.turso.io

# Your Turso authentication token (get this from your Turso dashboard)
VITE_TURSO_AUTH_TOKEN=your-auth-token-here
